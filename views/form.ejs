<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Message Board</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <main class="container">
        <form method="POST" action="/new">
            <h3>New message</h3>
            <div class="form-group">
                <label for="messageUser">Name</label>
                <input class="form-input" type="text" name="messageUser" id="messageUser">
            </div>
            <div class="form-group">
                <label for="messageText">Text</label>
                <input class="form-input" type="text" name="messageText" id="messageText">
            </div>
            <div class="form-check">
                <input class="form-input-check" type="checkbox" name="askUser" id="askUser">
                <label for="askUser">Save to History</label>
            </div>
            <button type="submit">Submit</button>
        </form>
    </main>
</body>

</html>